{
  "name": "take-home-assessment",
  "version": "1.0.0",
  "description": "Playwright BDD test automation framework with POM design pattern",
  "scripts": {
    "test": "bddgen && playwright test",
    "test:api": "bddgen && playwright test --project=chromium --grep @api",
    "test:headed": "bddgen && playwright test --headed --grep @ui",
    "test:chromium": "bddgen && playwright test --project=chromium --grep @ui",
    "test:firefox": "bddgen && playwright test --project=firefox --grep @ui",
    "test:webkit": "bddgen && playwright test --project=webkit --grep @ui",
    "bddgen": "bddgen",
    "generate:codeowners": "node scripts/generate-codeowners.js",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.3",
    "dotenv": "^16.6.1",
    "js-yaml": "^4.2.0",
    "playwright": "^1.44.0",
    "playwright-bdd": "^9.1.0",
    "typescript": "^5.4.5"
  }
}
